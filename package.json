{
  "name": "@payvia-sdk/sdk",
  "version": "1.3.0",
  "description": "A lightweight JavaScript SDK for connecting your Chrome Extension / SaaS app to PayVia, for accepting PayPal and Tranzila payments and managing subscriptions, license validation, tier-based feature gating, trial management and monthly / yearly / lifetime plans",
  "main": "payvia.js",
  "types": "payvia.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./payvia.d.ts",
      "import": "./payvia.js",
      "default": "./payvia.js"
    }
  },
  "files": [
    "payvia.js",
    "payvia.d.ts",
    "README.md"
  ],
  "scripts": {
    "build:types": "tsc",
    "prepublishOnly": "npm run build:types"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "keywords": [
    "paypal",
    "payments",
    "chrome-extension",
    "saas",
    "subscriptions",
    "monetization",
    "typescript"
  ],
  "author": "PayVia",
  "license": "MIT",
  "homepage": "https://payvia.site",
  "repository": {
    "type": "git",
    "url": "https://github.com/Asia-Digital/PayVia-SDK.git"
  },
  "bugs": {
    "url": "https://github.com/Asia-Digital/PayVia-SDK/issues"
  }
}
